{
  "name": "cisco-ios-lsp",
  "displayName": "Cisco IOS/IOS-XE IntelliSense",
  "description": "Context-aware completions, hover docs, and diagnostics for Cisco IOS/IOS-XE config files.",
  "version": "0.2.0",
  "publisher": "Aswertus",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aswertus/cisco-lsp"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "cisco",
    "ios",
    "ios-xe",
    "network",
    "lsp",
    "intellisense"
  ],
  "extensionDependencies": [
    "Y-Ysss.cisco-config-highlight"
  ],
  "activationEvents": [
    "onLanguage:cisco"
  ],
  "main": "./client/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "cisco",
        "extensions": [
          ".cfg",
          ".ios"
        ]
      }
    ],
    "configuration": {
      "title": "Cisco IOS IntelliSense",
      "properties": {
        "cisco-ios-lsp.checkForUpdates": {
          "type": "boolean",
          "default": true,
          "description": "On startup, check GitHub Releases for a newer version and notify if one is available. Inactive while the repository is private."
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint client server",
    "format": "prettier --write \"**/*.{js,json,md}\" --ignore-path .gitignore",
    "vscode:prepublish": "npm run lint",
    "package": "vsce package",
    "render-icon": "node scripts/render-icon.js"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.0.0"
  }
}
